from datasets import load_dataset
from torch.utils.data import IterableDataset
import torch


class StreamingTextDataset(IterableDataset):
    """
    Streaming dataset for large text corpora.
    
    Loads data on-the-fly, tokenizes, and packs into sequences.
    """
    
    def __init__(
        self,
        dataset_name: str,
        tokenizer,
        max_seq_len: int = 1024,
        split: str = "train"
    ):
        """
        Args:
            dataset_name: HuggingFace dataset name
            tokenizer: Tokenizer instance
            max_seq_len: Maximum sequence length
            split: Dataset split (train/validation)
        """
        self.tokenizer = tokenizer
        self.max_seq_len = max_seq_len
        
        # Load dataset in streaming mode
        self.dataset = load_dataset(
            dataset_name,
            split=split,
            streaming=True
        )
        
        # Buffer for packing sequences
        self.buffer = []
    
    def __iter__(self):
        """Iterate over dataset, yielding packed sequences."""
        for example in self.dataset:
            # Tokenize text
            tokens = self.tokenizer.encode(example['text'])
            
            # Add to buffer
            self.buffer.extend(tokens)
            
            # Yield complete sequences
            while len(self.buffer) >= self.max_seq_len + 1:
                # Extract sequence
                sequence = self.buffer[:self.max_seq_len + 1]
                self.buffer = self.buffer[self.max_seq_len:]
                
                # Create input and target
                input_ids = torch.tensor(sequence[:-1], dtype=torch.long)
                target_ids = torch.tensor(sequence[1:], dtype=torch.long)
                
                yield {
                    'input_ids': input_ids,
                    'target_ids': target_ids
                }


def test_streaming_dataset():
