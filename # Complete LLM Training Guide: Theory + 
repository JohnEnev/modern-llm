import torch
import torch.nn.functional as F
from pathlib import Path
import json


class Trainer:
    """
    Training loop for GPT model.
    """
    
    def __init__(
        self,
        model,
        optimizer,
        scheduler,
        device: str = 'cuda',
        grad_accum_steps: int = 1,
        max_grad_norm: float = 1.0,
        checkpoint_dir: str = 'checkpoints'
    ):
        """
        Args:
            model: GPT model
            optimizer: Optimizer
            scheduler: LR scheduler
            device: Device to train on
            grad_accum_steps: Gradient accumulation steps
            max_grad_norm: Max gradient norm for clipping
            checkpoint_dir: Directory to save checkpoints
        """
        self.model = model.to(device)
        self.optimizer = optimizer
        self.scheduler = scheduler
        self.device = device
        self.grad_accum_steps = grad_accum_steps
        self.max_grad_norm = max_grad_norm
        
        self.checkpoint_dir = Path(checkpoint_dir)
        self.checkpoint_dir.mkdir(exist_ok=True)
        
        self.step = 0
        self.tokens_seen = 0
    
    def train_step(self, batch):
        """
        Single training step.
        
        Args:
            batch: Dictionary with 'input_ids' and 'target_ids'
        
        Returns:
            loss: Scalar loss value
        """
        input_ids = batch['input_ids'].to(self.device)
        target_ids = batch['target_ids'].to(self.device)
        
        # Forward pass
        with torch.autocast('cuda', dtype=torch.bfloat16):
            logits, loss = self.model(input_ids, target_ids)
        
        # Scale loss for gradient accumulation
        loss = loss / self.grad_accum_steps
        
        # Backward pass
        loss.backward()
        
        # Update tokens seen
        self.tokens_seen += input_ids.numel()
        
        return loss.item() * self.grad_accum_steps
    
    def train(
        self,
        dataloader,
        max_steps: int,
        eval_every: int = 1000,
        save_every: int = 5000,
        log_every: int = 100
    ):
        """
        Main training loop.
        
        Args:
            dataloader: Training dataloader
            max_steps: Maximum training steps
            eval_every: Evaluate every N steps
            save_every: Save checkpoint every N steps
            log_every: Log metrics every N steps
        """
        self.model.train()
        
        running_loss = 0.0
        step_in_accum = 0
        
        for batch in dataloader:
            # Training step
            loss = self.train_step(batch)
            running_loss += loss
            step_in_accum += 1
            
            # Gradient accumulation
            if step_in_accum == self.grad_accum_steps:
                # Clip gradients
                torch.nn.utils.clip_grad_norm_(
                    self.model.parameters(),
                    self.max_grad_norm
                )
                
                # Optimizer step
                self.optimizer.step()
                self.scheduler.step()
                self.optimizer.zero_grad()
                
                self.step += 1
                step_in_accum = 0
                
                # Logging
                if self.step % log_every == 0:
                    avg_loss = running_loss / log_every
                    lr = self.scheduler.get_lr()[0]
                    print(f"Step {self.step} | Loss: {avg_loss:.4f} | LR: {lr:.6f} | Tokens: {self.tokens_seen:,}")
                    running_loss = 0.0
                
                # Save checkpoint
                if self.step % save_every == 0:
                    self.save_checkpoint(f'checkpoint_step_{self.step}.pt')
                
                # Stop if max steps reached
                if self.step >= max_steps:
                    print(f"Reached max steps: {max_steps}")
                    return
    
    def save_checkpoint(self, filename: str):
        """Save training checkpoint."""
        checkpoint = {
            'step': self.step,
            'tokens_seen': self.tokens_seen,
            'model_state_dict': self.model.state_dict(),
            'optimizer_state_dict': self.optimizer.state_dict(),
            'scheduler_state_dict': self.scheduler.__dict__,
        }
        
        path = self.checkpoint_dir / filename
        torch.save(checkpoint, path)
        print(f"Saved checkpoint: {path}")
    
    def load_checkpoint(self, filename: str):
        """Load training checkpoint."""
        path = self.checkpoint_dir / filename
        checkpoint = torch.load(path)
        
        self.step = checkpoint['step']
        self.tokens_seen = checkpoint['tokens_seen']
        self.model.load_state_dict(checkpoint['model_state_dict'])
        self.optimizer.load_state_dict(checkpoint['optimizer_state_dict'])
        
        print(f"Loaded checkpoint from step {self.step}")
